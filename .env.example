# --- SelfAuthenticator Konfiguration ---

# PFLICHT: Master-Secret (signiert JWTs, leitet Anti-Enumeration-Salt ab).
# Erzeugen mit:  python -c "import secrets; print(secrets.token_hex(32))"
SELFAUTH_SECRET=

# Host-Port (Container lauscht intern immer auf 8091)
PORT=8091

# Selbst-Registrierung. Nach dem Anlegen deines Accounts auf false setzen.
SELFAUTH_ALLOW_REGISTRATION=true

# Zeitzone
TZ=Europe/Berlin
